# Oracle Environment Configuration
# Copy this file to .env and customize as needed
# After deploying new smart contracts, update the addresses below

# ==========================================
# BLOCKCHAIN CONNECTION
# ==========================================
RPC_URL=http://localhost:8545

# ==========================================
# SMART CONTRACT ADDRESSES
# Update these after each deployment!
# ==========================================
ORGANIZATION_ADDRESS=0x4060eF0D5a7F0633c5927F7E05041dd7Fcd95f42
TASK_MANAGER_ADDRESS=0x15E1268353F6F19D9de2722bD60eC1081b45D3a6
SERVICE_MANAGER_ADDRESS=0xD7a385546a6a2355C6a1DfAdf33b55c43e2C19B0
IECOIN_ADDRESS=0xb7278A61aa25c888815aFC32Ad3cC52fF24fE575

# ==========================================
# WALLET CONFIGURATION
# Oracle wallet that validates and signs outcomes
# ==========================================
ORACLE_ADDRESS=0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC
ORACLE_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a

# ==========================================
# FILE PATHS (usually don't need to change)
# ==========================================
ADDRESSES_JSON=/workspace/addresses.json
BASE_ABI=/workspace/abi
TASK_MANAGER_NAME=TaskManager

# Gas Settings
MIN_GAS_PRICE=1000000000
GAS_MULTIPLIER=1.2
# GAS_PRICE_OVERRIDE=2000000000

# RosBag Validator Settings
PLAY_RATE=3.0
MIN_STATE_SEC=0.5
POS_EPS=0.002
ARM_POS_EPS=0.005
ARM_TOTAL_DELTA_TOL=0.05
MIN_ARM_STATE_SEC=0.0
MIN_PATH_METERS=0.10

# Energy Calculation
IEC_PER_KWH=1.0
IEC_DECIMALS=18

# ROS Configuration (for host network mode)
ROS_MASTER_URI=http://localhost:11311
ROS_IP=127.0.0.1
ROS_HOSTNAME=localhost
ROS_DISTRO=noetic
