# Organization Web Console Configuration
# Copy this file to .env and fill in your values

# ========================================
# Blockchain Configuration
# ========================================
# RPC endpoint for Ethereum/Ganache
RPC_URL=http://10.205.10.9:8545

# ========================================
# Contract Addresses
# ========================================
# Organization contract address
ORGANIZATION_ADDRESS=0xcEC91d876E8f003110D43381359b1bAd124e7F2b

# IECoin token contract address
IECOIN_ADDRESS=0x0B306BF915C4d645ff596e518fAf3F9669b97016

# ========================================
# Organization Wallet Credentials
# ========================================
# Public address of the organization wallet
ORGANIZATION_WALLET_PUBLIC=0x70997970C51812dc3A010C7d01b50e0d17dc79C8

# Private key of the organization wallet (KEEP SECURE!)
ORGANIZATION_WALLET_PRIVATE=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# ========================================
# Application Configuration
# ========================================
# Port to expose the web console
HOST_PORT=8080

# Base URL for API calls from frontend
NEXT_PUBLIC_API_BASE=http://localhost:8080

# ABI files root directory (relative to /app in container)
ABI_ROOT=contracts

# Path to addresses.json file (if using file-based config)
ADDRESSES_JSON=addresses.json

# CORS origins (usually empty when using nginx proxy)
CORS_ORIGINS=

# Optional: IECoin deployment block number (optimization for token holder scanning)
# IECOIN_DEPLOY_BLOCK=0

# ========================================
# Notes
# ========================================
# - The container runs backend on port 8000 and frontend on port 3000 internally
# - Nginx reverse proxy serves both on port 80
# - HOST_PORT maps container port 80 to host
# - Private keys should be kept secure in production
# - Use environment-specific .env files (.env.dev, .env.prod) for different deployments
