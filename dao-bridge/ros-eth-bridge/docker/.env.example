# ROS-ETH Bridge Docker Configuration
# Copy this file to .env and customize

# ========================================
# ROS Configuration
# ========================================
# ROS Master URI (where roscore is running)
ROS_MASTER_URI=http://localhost:11311

# ROS IP (IP address of this node)
ROS_IP=127.0.0.1

# ROS Hostname
ROS_HOSTNAME=localhost

# ========================================
# Wallet Configuration
# ========================================
# Path to wallet JSON keystore file on host
# This wallet will be used to sign all blockchain transactions
WALLET_PATH=~/.ros_eth/wallet.json

# Wallet passphrase (leave empty if no passphrase)
# WARNING: Setting password here is insecure. Better to use prompt or separate secrets.
ETH_WALLET_PASSPHRASE=

# ========================================
# ABI Configuration (Optional)
# ========================================
# Path to ABI files directory on host
# Default: uses ABIs from catkin workspace
ABI_PATH=./catkin_ws/src/ros_eth_bridge/abi

# Optional: Override dao.yaml location
# ROS_ETH_DAO_YAML=/path/to/custom/dao.yaml

# ========================================
# Notes
# ========================================
# 1. Contract addresses must be updated in configs/dao.yaml
# 2. Wallet file must exist at WALLET_PATH before starting
# 3. ROS Master must be running before bridge starts
# 4. Uses host network mode for ROS communication
# 5. See dao.yaml.template for configuration structure
